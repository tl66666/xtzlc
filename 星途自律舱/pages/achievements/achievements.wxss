.cabinet-head {
  padding: 26rpx;
  margin-bottom: 24rpx;
}

.intro {
  margin-top: 12rpx;
  font-size: 26rpx;
}

.achievement-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.badge {
  position: relative;
  min-height: 270rpx;
  padding: 24rpx;
  overflow: hidden;
}

.badge::after {
  content: "";
  position: absolute;
  right: -42rpx;
  top: -46rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(245,200,66,0.1);
}

.badge.locked {
  opacity: 0.66;
  filter: grayscale(0.7);
}

.badge.unlocked {
  border-color: rgba(245,200,66,0.28);
}

.badge-orbit {
  position: relative;
  width: 92rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(245,200,66,0.4);
  border-radius: 50%;
  background:
    radial-gradient(circle at 34% 26%, rgba(255,255,255,0.9), transparent 22%),
    rgba(255,255,255,0.5);
}

.badge-image {
  position: absolute;
  inset: 4rpx;
  width: 84rpx;
  height: 84rpx;
  opacity: 0.3;
}

.badge-icon {
  position: relative;
  z-index: 1;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #050a18;
  font-size: 23rpx;
  font-weight: 900;
  box-shadow: 0 10rpx 22rpx rgba(91,75,45,0.12);
}

.badge-name {
  margin-top: 22rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.badge-desc {
  margin-top: 8rpx;
  min-height: 64rpx;
  color: rgba(23,32,51,0.58);
  font-size: 22rpx;
  line-height: 1.45;
}

.badge-time {
  margin-top: 16rpx;
  color: #9a651f;
  font-size: 22rpx;
}
