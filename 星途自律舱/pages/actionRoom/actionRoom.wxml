<view class="page action-room-page">
  <image class="page-bg" src="{{assets.appBg}}" mode="aspectFill"></image>

  <view class="room-hero">
    <image class="room-scene" src="{{sceneImage}}" mode="aspectFill"></image>
    <view class="room-shade"></view>
    <view class="room-topline">
      <view>
        <view class="scan-label light">沉浸行动</view>
        <view class="room-title">{{room.roomName}}</view>
        <view class="room-guide">{{room.guide}}</view>
      </view>
      <view class="room-badge" style="color: {{dimension.color}};">{{dimension.name}}</view>
    </view>
  </view>

  <view class="cockpit cabin-panel">
    <view class="cockpit-head">
      <view>
        <view class="scan-label">当前任务</view>
        <view class="action-name">{{actionTitle}}</view>
        <view class="source-line">{{sourceLabel}} · {{dimension.sceneName}}</view>
      </view>
      <view class="phase-pill" style="color: {{dimension.color}};">{{phaseText}}</view>
    </view>

    <view class="timer-core">
      <view class="timer-orbit" style="border-color: {{dimension.color}};">
        <view class="timer-text">{{timerText}}</view>
        <view class="timer-sub">已投入时间</view>
      </view>
      <view class="timer-side">
        <view class="time-row">
          <view>
            <view class="time-label">开始</view>
            <view class="time-value">{{startTimeText}}</view>
          </view>
          <view>
            <view class="time-label">目标</view>
            <view class="time-value">{{targetMinutes}} 分钟</view>
          </view>
        </view>
        <view class="status-copy">{{statusText}}</view>
        <view class="target-track">
          <view class="target-fill" style="width: {{targetProgress}}%; background: {{dimension.color}};"></view>
        </view>
        <view class="target-text">目标进度 {{targetProgress}}%</view>
      </view>
    </view>

    <view class="control-row">
      <view wx:if="{{!running}}" class="main-control" bindtap="startFocus">{{hasStarted ? '继续行动' : room.actionVerb}}</view>
      <view wx:else class="main-control pause" bindtap="pauseFocus">暂停一下</view>
      <view class="minor-control" bindtap="resetFocus">重置</view>
    </view>
  </view>

  <view class="focus-panel cabin-panel">
    <view class="scan-label">行动内容</view>
    <view class="focus-title">你现在具体在做什么？</view>
    <view class="label-row">
      <view
        wx:for="{{room.focusLabels}}"
        wx:key="*this"
        class="label-chip {{actionTitle === item ? 'active' : ''}}"
        style="{{actionTitle === item ? 'background: ' + dimension.color : ''}}"
        data-value="{{item}}"
        bindtap="chooseFocusLabel"
      >{{item}}</view>
    </view>
    <textarea
      class="outcome-input"
      value="{{outcome}}"
      placeholder="完成后写一句结果，例如：刷完两道算法题 / 写完登录页 / 跑步 3 公里"
      bindinput="inputOutcome"
    ></textarea>
  </view>

  <view class="room-spacer"></view>
  <view class="finish-dock">
    <view class="dock-info">
      <view>{{timerText}}</view>
      <text>{{hasStarted ? statusText : '开始后才会累计时间'}}</text>
    </view>
    <view class="finish-button {{hasStarted ? '' : 'disabled'}}" style="background: {{hasStarted ? dimension.color : '#d7ccba'}};" bindtap="finishAction">{{room.finishVerb}}</view>
  </view>

  <cover-view wx:if="{{result}}" class="result-mask" catchtouchmove="noop">
    <cover-view class="result-card">
      <cover-view class="result-glow" style="background: {{dimension.color}};"></cover-view>
      <cover-image wx:if="{{assets.rewardChest}}" class="result-chest" src="{{assets.rewardChest}}"></cover-image>
      <cover-view class="scan-label">星光结算</cover-view>
      <cover-view class="result-title">{{result.actionName}} 已完成</cover-view>
      <cover-view class="result-copy">{{result.sourceLabel}} · 从 {{result.startTimeText}} 开始，累计 {{result.spentTime}}</cover-view>
      <cover-view class="result-outcome">{{result.outcome}}</cover-view>

      <cover-view class="result-numbers">
        <cover-view>
          <cover-view class="result-num">+{{result.starlight}}</cover-view>
          <cover-view class="result-label">本次星光</cover-view>
        </cover-view>
        <cover-view>
          <cover-view class="result-num">{{result.completedCount}}/6</cover-view>
          <cover-view class="result-label">今日点亮</cover-view>
        </cover-view>
        <cover-view>
          <cover-view class="result-num">{{result.starCoins}}</cover-view>
          <cover-view class="result-label">星光币</cover-view>
        </cover-view>
      </cover-view>

      <cover-view class="result-progress">
        <cover-view class="result-progress-head">
          <cover-view>{{result.chestLabel}}</cover-view>
          <cover-view wx:if="{{result.nextDimensionName}}">下一类：{{result.nextDimensionName}}</cover-view>
        </cover-view>
        <cover-view class="result-track">
          <cover-view class="result-fill" style="width: {{result.chestProgress}}%;"></cover-view>
        </cover-view>
      </cover-view>

      <cover-view class="result-unlock">
        <cover-image wx:if="{{assets.unlockBadge}}" src="{{assets.unlockBadge}}" class="unlock-icon"></cover-image>
        <cover-view>
          <cover-view class="unlock-name">{{result.unlockName || dimension.sceneName}}</cover-view>
          <cover-view class="unlock-desc">{{result.unlockDesc}}</cover-view>
        </cover-view>
      </cover-view>

      <cover-view wx:if="{{result.achievementName}}" class="achievement-pill">新成就：{{result.achievementName}}</cover-view>

      <cover-view class="result-actions">
        <cover-view class="result-ghost" bindtap="goCheckin">继续打卡</cover-view>
        <cover-view class="result-primary" bindtap="goEcology">查看生态变化</cover-view>
      </cover-view>
    </cover-view>
  </cover-view>
</view>
