.action-room-page {
  padding-bottom: 170rpx;
}

.room-hero {
  position: relative;
  height: 430rpx;
  overflow: hidden;
  border-radius: 0 0 42rpx 42rpx;
  margin: -30rpx -30rpx 0;
  background: #e9f3f4;
}

.room-scene {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.room-shade {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.02), rgba(9,18,32,0.22) 42%, rgba(9,18,32,0.62)),
    radial-gradient(circle at 50% 18%, transparent 0 26%, rgba(255,255,255,0.16) 68%);
}

.room-topline {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 32rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 22rpx;
}

.scan-label.light {
  color: rgba(255,244,207,0.95);
}

.room-title {
  margin-top: 8rpx;
  color: #fff;
  font-size: 42rpx;
  line-height: 1.12;
  font-weight: 900;
  text-shadow: 0 8rpx 24rpx rgba(0,0,0,0.28);
}

.room-guide {
  margin-top: 12rpx;
  max-width: 470rpx;
  color: rgba(255,255,255,0.86);
  font-size: 23rpx;
  line-height: 1.45;
}

.room-badge {
  flex: 0 0 auto;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.9);
  font-size: 23rpx;
  font-weight: 900;
}

.cockpit {
  margin-top: -36rpx;
  padding: 26rpx;
}

.cockpit-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.action-name {
  margin-top: 8rpx;
  color: #172033;
  font-size: 34rpx;
  line-height: 1.18;
  font-weight: 900;
}

.source-line {
  margin-top: 8rpx;
  color: rgba(23,32,51,0.52);
  font-size: 21rpx;
  font-weight: 800;
}

.phase-pill {
  flex: 0 0 auto;
  padding: 12rpx 15rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.72);
  font-size: 21rpx;
  font-weight: 900;
}

.timer-core {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: 210rpx 1fr;
  gap: 22rpx;
  align-items: center;
}

.timer-orbit {
  width: 190rpx;
  height: 190rpx;
  border: 8rpx solid #d9972f;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.72);
  box-shadow: inset 0 -14rpx 34rpx rgba(91,75,45,0.08), 0 22rpx 42rpx rgba(91,75,45,0.12);
}

.timer-text {
  color: #172033;
  font-size: 44rpx;
  font-weight: 900;
  font-variant-numeric: tabular-nums;
}

.timer-sub {
  margin-top: 6rpx;
  color: rgba(23,32,51,0.52);
  font-size: 20rpx;
  font-weight: 800;
}

.timer-side {
  min-width: 0;
}

.time-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.time-row > view {
  padding: 14rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,0.62);
}

.time-label {
  color: rgba(23,32,51,0.46);
  font-size: 19rpx;
  font-weight: 900;
}

.time-value {
  margin-top: 5rpx;
  color: #172033;
  font-size: 26rpx;
  font-weight: 900;
  font-variant-numeric: tabular-nums;
}

.status-copy {
  margin-top: 14rpx;
  color: rgba(23,32,51,0.62);
  font-size: 22rpx;
  line-height: 1.42;
}

.target-track {
  margin-top: 14rpx;
  height: 10rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(23,32,51,0.1);
}

.target-fill {
  height: 100%;
  border-radius: inherit;
  transition: width 0.2s ease;
}

.target-text {
  margin-top: 8rpx;
  color: rgba(23,32,51,0.48);
  font-size: 19rpx;
  font-weight: 800;
}

.control-row {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 1fr 156rpx;
  gap: 12rpx;
}

.main-control,
.minor-control {
  height: 78rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 900;
}

.main-control {
  color: #120f05;
  background: #f5c842;
}

.main-control.pause {
  background: #ffe0c4;
}

.minor-control {
  color: #8f5b18;
  background: rgba(245,200,66,0.12);
}

.focus-panel {
  margin-top: 24rpx;
  padding: 28rpx;
}

.focus-title {
  margin-top: 8rpx;
  color: #172033;
  font-size: 32rpx;
  font-weight: 900;
}

.label-row {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.label-chip {
  padding: 14rpx 18rpx;
  border: 1rpx solid rgba(23,32,51,0.08);
  border-radius: 999rpx;
  color: rgba(23,32,51,0.66);
  background: rgba(255,255,255,0.62);
  font-size: 23rpx;
  font-weight: 900;
}

.label-chip.active {
  color: #fff;
  border-color: transparent;
}

.outcome-input {
  margin-top: 22rpx;
  width: 100%;
  height: 132rpx;
  box-sizing: border-box;
  padding: 20rpx;
  border: 1rpx solid rgba(23,32,51,0.08);
  border-radius: 22rpx;
  color: #172033;
  background: rgba(255,255,255,0.72);
  font-size: 25rpx;
  line-height: 1.45;
}

.room-spacer {
  height: 110rpx;
}

.finish-dock {
  position: fixed;
  z-index: 50;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  display: grid;
  grid-template-columns: 1fr 220rpx;
  gap: 14rpx;
  align-items: center;
  background: rgba(248,241,229,0.94);
  border-top: 1rpx solid rgba(181,118,34,0.12);
  box-shadow: 0 -18rpx 48rpx rgba(91,75,45,0.12);
}

.dock-info {
  min-width: 0;
}

.dock-info view {
  color: #172033;
  font-size: 30rpx;
  font-weight: 900;
  font-variant-numeric: tabular-nums;
}

.dock-info text {
  display: block;
  margin-top: 5rpx;
  color: rgba(23,32,51,0.52);
  font-size: 19rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.finish-button {
  height: 82rpx;
  border-radius: 22rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  font-weight: 900;
  box-shadow: 0 18rpx 38rpx rgba(91,75,45,0.16);
}

.finish-button.disabled {
  color: rgba(23,32,51,0.42);
  box-shadow: none;
}

.result-mask {
  position: fixed;
  z-index: 100;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(244,240,231,0.72);
}

.result-card {
  position: relative;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  padding: 34rpx 28rpx 28rpx;
  border-radius: 36rpx;
  background: rgba(255,255,255,0.98);
  box-shadow: 0 40rpx 110rpx rgba(91,75,45,0.26);
  text-align: center;
}

.result-glow {
  position: absolute;
  right: -110rpx;
  top: -130rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  opacity: 0.18;
  filter: blur(18rpx);
}

.result-chest {
  position: relative;
  z-index: 1;
  width: 150rpx;
  height: 150rpx;
  margin: 0 auto 6rpx;
}

.result-title {
  position: relative;
  z-index: 1;
  margin-top: 8rpx;
  color: #172033;
  font-size: 38rpx;
  line-height: 1.16;
  font-weight: 900;
}

.result-copy,
.result-outcome {
  position: relative;
  z-index: 1;
  margin-top: 10rpx;
  color: rgba(23,32,51,0.62);
  font-size: 23rpx;
  line-height: 1.45;
}

.result-outcome {
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(244,240,231,0.62);
}

.result-numbers {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.result-numbers > cover-view {
  padding: 14rpx 8rpx;
  border-radius: 18rpx;
  background: rgba(245,200,66,0.1);
}

.result-num {
  color: #9a651f;
  font-size: 30rpx;
  font-weight: 900;
}

.result-label {
  margin-top: 4rpx;
  color: rgba(23,32,51,0.54);
  font-size: 19rpx;
}

.result-progress {
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: rgba(244,240,231,0.68);
}

.result-progress-head {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  color: rgba(23,32,51,0.62);
  font-size: 20rpx;
  font-weight: 900;
}

.result-track {
  margin-top: 12rpx;
  height: 8rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(23,32,51,0.1);
}

.result-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #f5c842, #8fd68f);
}

.result-unlock {
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
  padding: 16rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  border-radius: 20rpx;
  background: rgba(245,200,66,0.12);
  text-align: left;
}

.unlock-icon {
  width: 68rpx;
  height: 68rpx;
  flex: 0 0 68rpx;
}

.unlock-name {
  color: #172033;
  font-size: 26rpx;
  font-weight: 900;
}

.unlock-desc {
  margin-top: 7rpx;
  color: rgba(23,32,51,0.58);
  font-size: 21rpx;
  line-height: 1.38;
}

.achievement-pill {
  position: relative;
  z-index: 1;
  margin-top: 14rpx;
  padding: 13rpx 18rpx;
  border-radius: 999rpx;
  color: #8f5b18;
  background: rgba(245,200,66,0.14);
  font-size: 22rpx;
  font-weight: 900;
}

.result-actions {
  position: relative;
  z-index: 1;
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.result-ghost,
.result-primary {
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 900;
}

.result-ghost {
  color: #8f5b18;
  background: rgba(245,200,66,0.12);
}

.result-primary {
  color: #120f05;
  background: #f5c842;
}
