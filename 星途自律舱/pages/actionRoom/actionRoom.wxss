.action-room-page {
  padding-bottom: 72rpx;
}

.room-hero {
  position: relative;
  height: 560rpx;
  overflow: hidden;
  border-radius: 0 0 42rpx 42rpx;
  margin: -30rpx -30rpx 0;
  background: #e9f3f4;
}

.room-scene {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.room-shade {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.1), rgba(244,240,231,0.08) 36%, rgba(9,18,32,0.52)),
    radial-gradient(circle at 50% 32%, transparent 0 28%, rgba(255,255,255,0.18) 62%);
}

.room-topline {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 34rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 22rpx;
}

.room-title {
  margin-top: 8rpx;
  color: #fff;
  font-size: 46rpx;
  line-height: 1.12;
  font-weight: 900;
  text-shadow: 0 8rpx 24rpx rgba(0,0,0,0.28);
}

.room-guide {
  margin-top: 12rpx;
  max-width: 470rpx;
  color: rgba(255,255,255,0.84);
  font-size: 24rpx;
  line-height: 1.45;
}

.room-badge {
  flex: 0 0 auto;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.86);
  font-size: 23rpx;
  font-weight: 900;
}

.timer-panel {
  margin-top: 24rpx;
  padding: 26rpx;
  display: grid;
  grid-template-columns: 220rpx 1fr;
  gap: 24rpx;
  align-items: center;
}

.timer-ring {
  width: 196rpx;
  height: 196rpx;
  border: 8rpx solid #d9972f;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.66);
  box-shadow: inset 0 -14rpx 34rpx rgba(91,75,45,0.08), 0 22rpx 42rpx rgba(91,75,45,0.12);
}

.timer-text {
  color: #172033;
  font-size: 44rpx;
  font-weight: 900;
  font-variant-numeric: tabular-nums;
}

.timer-sub {
  margin-top: 6rpx;
  color: rgba(23,32,51,0.52);
  font-size: 21rpx;
  font-weight: 800;
}

.action-name {
  font-size: 34rpx;
  font-weight: 900;
}

.action-desc {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.45;
}

.timer-actions {
  margin-top: 22rpx;
  display: flex;
  gap: 12rpx;
}

.primary-control,
.minor-control {
  height: 76rpx;
  padding: 0 28rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 900;
}

.primary-control {
  color: #120f05;
  background: #f5c842;
}

.primary-control.pause {
  background: #ffe0c4;
}

.minor-control {
  color: #8f5b18;
  background: rgba(245,200,66,0.12);
}

.focus-panel {
  margin-top: 24rpx;
  padding: 28rpx;
}

.focus-title {
  margin-top: 8rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.label-row {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.label-chip {
  padding: 14rpx 18rpx;
  border: 1rpx solid rgba(23,32,51,0.08);
  border-radius: 999rpx;
  color: rgba(23,32,51,0.66);
  background: rgba(255,255,255,0.62);
  font-size: 23rpx;
  font-weight: 900;
}

.label-chip.active {
  color: #fff;
  border-color: transparent;
  background: #d9972f;
}

.outcome-input {
  margin-top: 22rpx;
  width: 100%;
  height: 156rpx;
  box-sizing: border-box;
  padding: 20rpx;
  border: 1rpx solid rgba(23,32,51,0.08);
  border-radius: 22rpx;
  color: #172033;
  background: rgba(255,255,255,0.72);
  font-size: 25rpx;
  line-height: 1.45;
}

.finish-button {
  margin-top: 20rpx;
  height: 88rpx;
  border-radius: 22rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 0 18rpx 38rpx rgba(91,75,45,0.16);
}

.tip-panel {
  margin-top: 22rpx;
  padding: 22rpx;
  display: flex;
  gap: 16rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.48);
}

.tip-dot {
  width: 18rpx;
  height: 58rpx;
  flex: 0 0 18rpx;
  border-radius: 999rpx;
}

.tip-title {
  font-size: 25rpx;
  font-weight: 900;
}

.tip-copy {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
}

.result-mask {
  position: fixed;
  z-index: 100;
  inset: 0;
  padding: 0 28rpx 38rpx;
  display: flex;
  align-items: flex-end;
  background: rgba(244,240,231,0.48);
}

.result-card {
  position: relative;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  padding: 34rpx 28rpx 26rpx;
  border-radius: 34rpx;
  background: rgba(255,255,255,0.96);
  box-shadow: 0 40rpx 100rpx rgba(91,75,45,0.24);
}

.result-glow {
  position: absolute;
  right: -100rpx;
  top: -120rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  opacity: 0.18;
  filter: blur(18rpx);
}

.result-title {
  position: relative;
  margin-top: 8rpx;
  font-size: 38rpx;
  font-weight: 900;
}

.result-copy {
  position: relative;
  margin-top: 10rpx;
  color: #9a651f;
  font-size: 25rpx;
  font-weight: 900;
}

.result-unlock {
  position: relative;
  margin-top: 20rpx;
  padding: 18rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-radius: 20rpx;
  background: rgba(245,200,66,0.12);
}

.result-unlock image {
  width: 72rpx;
  height: 72rpx;
  flex: 0 0 72rpx;
}

.unlock-name {
  font-size: 27rpx;
  font-weight: 900;
}

.unlock-desc {
  margin-top: 7rpx;
  font-size: 22rpx;
  line-height: 1.42;
}

.achievement-pill {
  position: relative;
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  color: #8f5b18;
  background: rgba(245,200,66,0.14);
  font-size: 23rpx;
  font-weight: 900;
}

.result-actions {
  position: relative;
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.result-ghost,
.result-primary {
  height: 82rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 900;
}

.result-ghost {
  color: #8f5b18;
  background: rgba(245,200,66,0.12);
}

.result-primary {
  color: #120f05;
  background: #f5c842;
}
