.plans-page {
  padding-bottom: 124rpx;
}

.plans-head,
.editor-head {
  position: relative;
  z-index: 1;
  padding: 22rpx 2rpx 14rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.head-subtitle {
  margin-top: 8rpx;
  font-size: 23rpx;
}

.new-plan-pill,
.back-pill {
  flex: 0 0 auto;
  min-width: 112rpx;
  height: 62rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #151006;
  background: #f5c842;
  box-shadow: 0 14rpx 26rpx rgba(217,151,47,0.18);
  font-size: 24rpx;
  font-weight: 900;
}

.back-pill {
  min-width: 92rpx;
  color: #8f5b18;
  background: rgba(255,255,255,0.76);
}

.plan-command,
.reminder-strip,
.empty-state,
.editor-card {
  margin-top: 18rpx;
  padding: 24rpx;
}

.command-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.command-title,
.empty-title {
  margin-top: 8rpx;
  color: #172033;
  font-size: 34rpx;
  line-height: 1.18;
  font-weight: 900;
}

.command-copy,
.empty-copy {
  margin-top: 9rpx;
  font-size: 23rpx;
  line-height: 1.45;
}

.command-ring {
  width: 126rpx;
  height: 126rpx;
  flex: 0 0 126rpx;
  border-radius: 38rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9a651f;
  background:
    radial-gradient(circle at 30% 22%, rgba(255,255,255,0.95), transparent 38%),
    linear-gradient(145deg, rgba(255,247,214,0.96), rgba(255,226,134,0.72));
  box-shadow: inset 0 -12rpx 24rpx rgba(151,91,13,0.08);
  font-size: 34rpx;
  font-weight: 900;
}

.command-ring text {
  margin-top: 2rpx;
  color: rgba(23,32,51,0.46);
  font-size: 19rpx;
  font-weight: 900;
}

.command-track {
  margin-top: 20rpx;
  height: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(23,32,51,0.1);
}

.command-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #f5c842, #8fd68f, #74c9e8);
  transition: width 0.2s ease;
}

.command-actions {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 12rpx;
}

.command-primary,
.command-secondary,
.plan-action {
  height: 76rpx;
  border-radius: 21rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
}

.command-primary {
  color: #120f05;
  background: #f5c842;
  box-shadow: 0 18rpx 34rpx rgba(217,151,47,0.18);
}

.command-secondary {
  color: #8f5b18;
  background: rgba(245,200,66,0.12);
}

.reminder-strip {
  display: grid;
  grid-template-columns: 22rpx 1fr auto;
  gap: 16rpx;
  align-items: center;
}

.reminder-dot {
  width: 18rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #f5c842, #8fd68f);
}

.reminder-title {
  color: #172033;
  font-size: 26rpx;
  font-weight: 900;
}

.reminder-copy {
  margin-top: 5rpx;
  font-size: 21rpx;
}

.reminder-count {
  padding: 12rpx 16rpx;
  border-radius: 18rpx;
  color: #9a651f;
  background: rgba(245,200,66,0.12);
  font-size: 24rpx;
  font-weight: 900;
}

.empty-state {
  text-align: left;
}

.empty-button {
  margin-top: 22rpx;
  height: 82rpx;
}

.plan-list {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
}

.plan-item {
  padding: 22rpx;
}

.plan-item.done {
  background: rgba(237,248,228,0.8);
}

.plan-main {
  display: flex;
  align-items: flex-start;
  gap: 15rpx;
}

.dimension-tag {
  width: 66rpx;
  height: 66rpx;
  flex: 0 0 66rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 -10rpx 20rpx rgba(0,0,0,0.08);
}

.dimension-tag image {
  width: 38rpx;
  height: 38rpx;
}

.plan-copy {
  min-width: 0;
  flex: 1;
}

.plan-title {
  color: #172033;
  font-size: 28rpx;
  line-height: 1.24;
  font-weight: 900;
}

.plan-desc {
  margin-top: 7rpx;
  font-size: 22rpx;
  line-height: 1.35;
}

.plan-meta {
  margin-top: 11rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 9rpx;
}

.plan-meta text {
  padding: 7rpx 11rpx;
  border-radius: 999rpx;
  color: #9a651f;
  background: rgba(245,200,66,0.11);
  font-size: 20rpx;
  font-weight: 900;
}

.plan-status {
  flex: 0 0 auto;
  padding: 9rpx 12rpx;
  border-radius: 999rpx;
  color: #8f5b18;
  background: rgba(245,200,66,0.14);
  font-size: 20rpx;
  font-weight: 900;
}

.plan-status.is-done {
  color: #3d8b3d;
  background: rgba(143,214,143,0.22);
}

.plan-actions {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 1.15fr 0.9fr 0.78fr 0.78fr;
  gap: 9rpx;
}

.plan-action {
  height: 68rpx;
  border-radius: 18rpx;
  color: #8f5b18;
  background: rgba(245,200,66,0.12);
  font-size: 22rpx;
}

.plan-action.primary {
  color: #151006;
  background: #f5c842;
}

.plan-action.ghost {
  color: rgba(23,32,51,0.58);
  background: rgba(255,255,255,0.64);
}

.plan-action.danger {
  color: #b46d54;
  background: rgba(180,109,84,0.1);
}

.editor-page {
  position: relative;
  z-index: 1;
}

.editor-card {
  padding-bottom: 28rpx;
}

.field-block {
  margin-top: 20rpx;
}

.field-block:first-child {
  margin-top: 0;
}

.field-label {
  margin-bottom: 10rpx;
  color: rgba(23,32,51,0.72);
  font-size: 22rpx;
  font-weight: 900;
}

.editor-input,
.time-input,
.editor-textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid rgba(23,32,51,0.08);
  border-radius: 20rpx;
  color: #172033;
  background: rgba(255,255,255,0.72);
  font-size: 25rpx;
  font-weight: 800;
}

.editor-input,
.time-input {
  height: 84rpx;
  padding: 0 20rpx;
}

.time-input {
  display: flex;
  align-items: center;
  color: #9a651f;
  background: rgba(245,200,66,0.14);
}

.editor-textarea {
  min-height: 132rpx;
  padding: 18rpx 20rpx;
  line-height: 1.45;
}

.dimension-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.dimension-choice {
  min-height: 92rpx;
  border: 2rpx solid rgba(23,32,51,0.08);
  border-radius: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 7rpx;
  background: rgba(255,255,255,0.62);
}

.dimension-choice.active {
  background: rgba(255,255,255,0.9);
  box-shadow: 0 14rpx 30rpx rgba(91,75,45,0.1);
}

.dimension-choice image {
  width: 34rpx;
  height: 34rpx;
}

.dimension-choice text {
  color: #172033;
  font-size: 22rpx;
  font-weight: 900;
}

.two-cols {
  display: grid;
  grid-template-columns: 1fr 176rpx;
  gap: 14rpx;
}

.reminder-row {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  background: rgba(245,200,66,0.1);
}

.editor-actions {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: 0.84fr 1.2fr;
  gap: 12rpx;
}

.delete-button,
.save-plan-button {
  height: 82rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 900;
}

.delete-button {
  color: #b46d54;
  background: rgba(180,109,84,0.1);
}

.save-plan-button {
  margin: 0;
}

.plan-result-layer {
  position: fixed;
  z-index: 100;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(244,240,231,0.72);
}

.plan-result-card {
  width: 100%;
  box-sizing: border-box;
  padding: 34rpx 28rpx 28rpx;
  border-radius: 36rpx;
  background: rgba(255,255,255,0.98);
  box-shadow: 0 40rpx 110rpx rgba(91,75,45,0.24);
  text-align: center;
}

.result-chest {
  width: 156rpx;
  height: 156rpx;
  margin: 0 auto 8rpx;
}

.result-mark {
  width: 116rpx;
  height: 116rpx;
  margin: 0 auto 14rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #151006;
  background: #f5c842;
  font-size: 58rpx;
  font-weight: 900;
}

.result-title {
  margin-top: 8rpx;
  color: #172033;
  font-size: 38rpx;
  line-height: 1.16;
  font-weight: 900;
}

.result-copy {
  margin-top: 10rpx;
  color: rgba(23,32,51,0.62);
  font-size: 23rpx;
  line-height: 1.45;
}

.result-stats {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.result-stats > cover-view {
  padding: 16rpx 8rpx;
  border-radius: 20rpx;
  background: rgba(245,200,66,0.1);
}

.result-num {
  color: #9a651f;
  font-size: 34rpx;
  font-weight: 900;
}

.result-label {
  margin-top: 4rpx;
  color: rgba(23,32,51,0.54);
  font-size: 20rpx;
}

.result-badge {
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  color: #8f5b18;
  background: rgba(245,200,66,0.14);
  font-size: 22rpx;
  font-weight: 900;
}

.result-actions {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.result-ghost,
.result-solid {
  height: 82rpx;
  border-radius: 21rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 900;
}

.result-ghost {
  color: #8f5b18;
  background: rgba(245,200,66,0.12);
}

.result-solid {
  color: #120f05;
  background: #f5c842;
}
