.plans-page {
  padding-bottom: 120rpx;
}

.plans-head,
.editor-head {
  position: relative;
  z-index: 1;
  padding: 24rpx 4rpx 18rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.head-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
}

.new-plan-pill,
.back-pill {
  flex: 0 0 auto;
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  color: #151006;
  background: #f5c842;
  box-shadow: 0 14rpx 26rpx rgba(217,151,47,0.18);
  font-size: 24rpx;
  font-weight: 900;
}

.back-pill {
  color: #8f5b18;
  background: rgba(255,255,255,0.72);
}

.plans-summary,
.next-card,
.empty-state,
.editor-card {
  margin-top: 18rpx;
  padding: 24rpx;
}

.plans-summary,
.next-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.summary-title,
.next-title,
.empty-title {
  margin-top: 8rpx;
  color: #172033;
  font-size: 32rpx;
  line-height: 1.25;
  font-weight: 900;
}

.summary-copy,
.empty-copy {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.5;
}

.summary-orb {
  width: 122rpx;
  height: 122rpx;
  flex: 0 0 122rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 38rpx;
  color: #9a651f;
  background: linear-gradient(145deg, rgba(255,255,255,0.94), rgba(255,238,181,0.74));
  font-size: 36rpx;
  font-weight: 900;
}

.summary-orb text {
  margin-top: 2rpx;
  color: rgba(23,32,51,0.48);
  font-size: 19rpx;
}

.next-button {
  flex: 0 0 auto;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  color: #151006;
  background: #f5c842;
  font-size: 22rpx;
  font-weight: 900;
}

.empty-state {
  text-align: left;
}

.empty-button {
  margin-top: 22rpx;
  height: 82rpx;
}

.plan-list {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
}

.plan-item {
  padding: 22rpx;
}

.plan-item.done {
  background: rgba(237,248,228,0.78);
}

.plan-item-top {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.dimension-tag {
  width: 62rpx;
  height: 62rpx;
  flex: 0 0 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
}

.dimension-tag image {
  width: 38rpx;
  height: 38rpx;
}

.plan-copy {
  min-width: 0;
  flex: 1;
}

.plan-title {
  color: #172033;
  font-size: 28rpx;
  font-weight: 900;
}

.plan-desc {
  margin-top: 7rpx;
  font-size: 22rpx;
  line-height: 1.35;
}

.plan-meta {
  margin-top: 10rpx;
  color: #9a651f;
  font-size: 21rpx;
  font-weight: 900;
}

.plan-status {
  flex: 0 0 auto;
  padding: 9rpx 13rpx;
  border-radius: 999rpx;
  color: #8f5b18;
  background: rgba(245,200,66,0.14);
  font-size: 20rpx;
  font-weight: 900;
}

.plan-status.is-done {
  color: #3d8b3d;
  background: rgba(143,214,143,0.2);
}

.plan-actions {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 1.25fr 1fr 0.72fr;
  gap: 10rpx;
}

.plan-action {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  color: #8f5b18;
  background: rgba(245,200,66,0.12);
  font-size: 22rpx;
  font-weight: 900;
}

.plan-action.primary {
  color: #151006;
  background: #f5c842;
}

.plan-action.ghost {
  color: rgba(23,32,51,0.56);
  background: rgba(255,255,255,0.62);
}

.editor-page {
  position: relative;
  z-index: 1;
}

.field-block {
  margin-top: 20rpx;
}

.field-block:first-child {
  margin-top: 0;
}

.field-label {
  margin-bottom: 10rpx;
  color: rgba(23,32,51,0.72);
  font-size: 22rpx;
  font-weight: 900;
}

.editor-input,
.time-input,
.editor-textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid rgba(23,32,51,0.08);
  border-radius: 20rpx;
  color: #172033;
  background: rgba(255,255,255,0.68);
  font-size: 25rpx;
  font-weight: 800;
}

.editor-input,
.time-input {
  height: 84rpx;
  padding: 0 20rpx;
}

.time-input {
  display: flex;
  align-items: center;
  color: #9a651f;
  background: rgba(245,200,66,0.14);
}

.editor-textarea {
  min-height: 132rpx;
  padding: 18rpx 20rpx;
  line-height: 1.45;
}

.two-cols {
  display: grid;
  grid-template-columns: 1fr 180rpx;
  gap: 14rpx;
}

.dimension-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.dimension-choice {
  min-height: 88rpx;
  box-sizing: border-box;
  padding: 12rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(23,32,51,0.08);
  border-radius: 20rpx;
  background: rgba(255,255,255,0.52);
  color: rgba(23,32,51,0.62);
  font-size: 20rpx;
  font-weight: 900;
}

.dimension-choice.active {
  color: #172033;
  background: rgba(255,255,255,0.9);
  box-shadow: 0 12rpx 26rpx rgba(91,75,45,0.1);
}

.dimension-choice image {
  width: 34rpx;
  height: 34rpx;
  margin-bottom: 7rpx;
}

.reminder-row {
  margin-top: 20rpx;
  padding: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.5);
}

.editor-actions {
  margin-top: 22rpx;
  display: flex;
  gap: 12rpx;
}

.delete-button,
.save-plan-button {
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 900;
}

.delete-button {
  flex: 0.65;
  color: rgba(176,67,53,0.92);
  background: rgba(176,67,53,0.08);
}

.save-plan-button {
  flex: 1;
}

.plan-result-layer {
  position: fixed;
  z-index: 999;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  padding: 0 24rpx 34rpx;
  display: flex;
  align-items: flex-end;
  background: rgba(244,240,231,0.5);
}

.plan-result-card {
  width: 100%;
  box-sizing: border-box;
  padding: 30rpx 24rpx 24rpx;
  border: 1rpx solid rgba(255,255,255,0.78);
  border-radius: 34rpx 34rpx 26rpx 26rpx;
  background: rgba(255,255,255,0.98);
  box-shadow: 0 36rpx 90rpx rgba(91,75,45,0.22);
  text-align: center;
}

.result-chest {
  width: 156rpx;
  height: 156rpx;
  margin: 0 auto 8rpx;
}

.result-title {
  margin-top: 8rpx;
  color: #172033;
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 900;
}

.result-copy {
  margin-top: 10rpx;
  color: rgba(23,32,51,0.62);
  font-size: 23rpx;
}

.result-stats {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.result-stats > cover-view {
  padding: 16rpx 8rpx;
  border-radius: 18rpx;
  background: rgba(245,200,66,0.1);
}

.result-num {
  color: #9a651f;
  font-size: 32rpx;
  font-weight: 900;
}

.result-label {
  margin-top: 4rpx;
  color: rgba(23,32,51,0.54);
  font-size: 20rpx;
}

.result-badge {
  margin-top: 14rpx;
  padding: 13rpx 18rpx;
  border-radius: 999rpx;
  color: #8f5b18;
  background: rgba(245,200,66,0.14);
  font-size: 22rpx;
  font-weight: 900;
}

.result-actions {
  margin-top: 18rpx;
  display: flex;
  gap: 12rpx;
}

.result-ghost,
.result-solid {
  height: 78rpx;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  font-size: 25rpx;
  font-weight: 900;
}

.result-ghost {
  color: #8f5b18;
  background: rgba(245,200,66,0.13);
}

.result-solid {
  color: #120f05;
  background: #f5c842;
}
