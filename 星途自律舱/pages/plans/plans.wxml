<view class="page plans-page">
  <image class="page-bg" src="{{assets.appBg}}" mode="aspectFill"></image>

  <cover-view wx:if="{{result}}" class="plan-result-layer" catchtouchmove="noop">
    <cover-view class="plan-result-card">
      <cover-image wx:if="{{assets.rewardChest && !result.saved}}" class="result-chest" src="{{assets.rewardChest}}"></cover-image>
      <cover-view wx:else class="result-mark">✓</cover-view>
      <cover-view class="scan-label">{{result.saved ? '计划已进入航线' : '今日计划完成'}}</cover-view>
      <cover-view class="result-title">{{result.title}}</cover-view>
      <cover-view class="result-copy">{{result.subtitle}}</cover-view>
      <cover-view wx:if="{{!result.saved}}" class="result-stats">
        <cover-view>
          <cover-view class="result-num">+{{result.starlight}}</cover-view>
          <cover-view class="result-label">星光</cover-view>
        </cover-view>
        <cover-view>
          <cover-view class="result-num">{{result.completedCount}}/6</cover-view>
          <cover-view class="result-label">今日点亮</cover-view>
        </cover-view>
      </cover-view>
      <cover-view wx:if="{{result.achievementName}}" class="result-badge">新成就：{{result.achievementName}}</cover-view>
      <cover-view class="result-actions">
        <cover-view class="result-ghost" bindtap="closeResult">留在计划</cover-view>
        <cover-view class="result-solid" bindtap="handleResultPrimary">{{result.primaryText || '查看变化'}}</cover-view>
      </cover-view>
    </cover-view>
  </cover-view>

  <view wx:if="{{mode === 'list'}}">
    <view class="plans-head">
      <view>
        <view class="scan-label">计划中心</view>
        <view class="section-title">今天要推进哪几件事？</view>
        <view class="muted head-subtitle">{{dateDisplay.fullText}}</view>
      </view>
      <view class="new-plan-pill" bindtap="createPlan">+ 新建</view>
    </view>

    <view class="plan-command cabin-panel">
      <view class="command-top">
        <view>
          <view class="scan-label">下一项行动</view>
          <view class="command-title">{{summary.nextTitle}}</view>
          <view class="muted command-copy">{{summary.nextSubtitle}}</view>
        </view>
        <view class="command-ring">
          <view>{{summary.percent}}%</view>
          <text>今日</text>
        </view>
      </view>
      <view class="command-track">
        <view class="command-fill" style="width: {{summary.percent}}%;"></view>
      </view>
      <view class="command-actions">
        <view class="command-primary" bindtap="startNextActionRoom">{{summary.next ? '进入行动舱' : '先创建计划'}}</view>
        <view class="command-secondary" bindtap="createPlan">添加计划</view>
      </view>
    </view>

    <view class="reminder-strip cabin-panel">
      <view class="reminder-dot"></view>
      <view>
        <view class="reminder-title">最近提醒</view>
        <view class="muted reminder-copy">{{summary.reminderLine}}</view>
      </view>
      <view class="reminder-count">{{summary.done}}/{{summary.total}}</view>
    </view>

    <view wx:if="{{!plans.length}}" class="empty-state cabin-panel">
      <view class="empty-title">还没有自己的计划</view>
      <view class="muted empty-copy">计划不是模板，而是你今天真的要做的事。写下行动、时间和目标量，之后就能直接进入行动舱计时。</view>
      <view class="primary-button empty-button" bindtap="createPlan">创建第一个计划</view>
    </view>

    <view wx:else class="plan-list">
      <view wx:for="{{plans}}" wx:key="id" class="plan-item cabin-panel {{item.doneToday ? 'done' : ''}}">
        <view class="plan-main">
          <view class="dimension-tag" style="background: {{item.color}};">
            <image src="{{item.icon}}" mode="aspectFit"></image>
          </view>
          <view class="plan-copy">
            <view class="plan-title">{{item.title}}</view>
            <view class="muted plan-desc">{{item.summary}}</view>
            <view class="plan-meta">
              <text>{{item.reminderText}}</text>
              <text>{{item.dimensionName}}</text>
            </view>
          </view>
          <view class="plan-status {{item.doneToday ? 'is-done' : ''}}">{{item.statusText}}</view>
        </view>
        <view class="plan-actions">
          <view class="plan-action primary" data-id="{{item.id}}" bindtap="startActionRoom">进舱</view>
          <view class="plan-action" data-id="{{item.id}}" bindtap="completeToday">{{item.doneToday ? '已记录' : '完成'}}</view>
          <view class="plan-action ghost" data-id="{{item.id}}" bindtap="openEditor">编辑</view>
          <view class="plan-action danger" data-id="{{item.id}}" bindtap="removePlan">删除</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="editor-page">
    <view class="editor-head">
      <view class="back-pill" bindtap="backToList">返回</view>
      <view>
        <view class="scan-label">计划编辑</view>
        <view class="section-title">{{draft.id ? '调整这条计划' : '新建一条可执行计划'}}</view>
      </view>
    </view>

    <view class="editor-card cabin-panel">
      <view class="field-block">
        <view class="field-label">计划名称</view>
        <input class="editor-input" value="{{draft.title}}" placeholder="例如：晚饭后背 30 个单词" bindinput="inputTitle" />
      </view>

      <view class="field-block">
        <view class="field-label">归属生态区</view>
        <view class="dimension-grid">
          <view
            wx:for="{{dimensions}}"
            wx:key="id"
            class="dimension-choice {{draft.dimension === item.id ? 'active' : ''}}"
            style="border-color: {{draft.dimension === item.id ? item.color : 'rgba(23,32,51,0.08)'}};"
            data-id="{{item.id}}"
            bindtap="selectDimension"
          >
            <image src="{{item.icon}}" mode="aspectFit"></image>
            <text>{{item.name}}</text>
          </view>
        </view>
      </view>

      <view class="field-block">
        <view class="field-label">具体行动</view>
        <input class="editor-input" value="{{draft.action}}" placeholder="{{actionPlaceholder}}" bindinput="inputAction" />
      </view>

      <view class="field-block two-cols">
        <view>
          <view class="field-label">目标量</view>
          <input class="editor-input" value="{{draft.metric}}" placeholder="45 分钟 / 3 页 / 1 轮" bindinput="inputMetric" />
        </view>
        <view>
          <view class="field-label">提醒时间</view>
          <picker mode="time" value="{{draft.reminderTime}}" bindchange="changeTime">
            <view class="time-input">{{draft.reminderTime}}</view>
          </picker>
        </view>
      </view>

      <view class="reminder-row">
        <view>
          <view class="field-label">每日提醒</view>
          <view class="muted">当前小程序会保存提醒时间；正式订阅通知可在微信后台接入模板。</view>
        </view>
        <switch checked="{{draft.reminderEnabled}}" color="#F5C842" bindchange="toggleReminder" />
      </view>

      <view class="field-block">
        <view class="field-label">验收标准 / 备注</view>
        <textarea class="editor-textarea" value="{{draft.note}}" placeholder="例如：做完后截图保存 / 写 3 行复盘 / 只推进一个任务" bindinput="inputNote"></textarea>
      </view>

      <view class="editor-actions">
        <view wx:if="{{draft.id}}" class="delete-button" data-id="{{draft.id}}" bindtap="removePlan">删除计划</view>
        <view class="primary-button save-plan-button" bindtap="saveDraft">{{draft.id ? '保存更新' : '保存并继续'}}</view>
      </view>
    </view>
  </view>
</view>
