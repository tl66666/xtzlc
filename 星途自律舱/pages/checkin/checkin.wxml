<view class="page checkin-page">
  <image class="page-bg" src="{{assets.appBg}}" mode="aspectFill"></image>

  <cover-view wx:if="{{rewardModal}}" class="reward-layer" catchtouchmove="noop">
    <cover-view class="reward-sheet">
      <cover-view class="reward-aura" style="background: {{rewardModal.color}};"></cover-view>
      <cover-image wx:if="{{assets.rewardChest}}" class="reward-chest" src="{{assets.rewardChest}}"></cover-image>
      <cover-view class="reward-kicker">本次行动已结算</cover-view>
      <cover-view class="reward-title">{{rewardModal.actionName}}</cover-view>
      <cover-view class="reward-copy">{{rewardModal.subtitle}}</cover-view>

      <cover-view class="reward-numbers">
        <cover-view class="reward-cell">
          <cover-view class="reward-number">+{{rewardModal.starlight}}</cover-view>
          <cover-view class="reward-cell-label">本次星光</cover-view>
        </cover-view>
        <cover-view class="reward-cell">
          <cover-view class="reward-number">{{rewardModal.completedCount}}/6</cover-view>
          <cover-view class="reward-cell-label">今日点亮</cover-view>
        </cover-view>
        <cover-view class="reward-cell">
          <cover-view class="reward-number">{{rewardModal.starCoins}}</cover-view>
          <cover-view class="reward-cell-label">星光币</cover-view>
        </cover-view>
      </cover-view>

      <cover-view class="reward-progress">
        <cover-view class="reward-progress-head">
          <cover-view>{{rewardModal.chestLabel}}</cover-view>
          <cover-view wx:if="{{rewardModal.nextDimensionName}}">下一个：{{rewardModal.nextDimensionName}}</cover-view>
        </cover-view>
        <cover-view class="reward-track">
          <cover-view class="reward-fill" style="width: {{rewardModal.chestProgress}}%;"></cover-view>
        </cover-view>
      </cover-view>

      <cover-view class="unlock-preview">
        <cover-image wx:if="{{assets.unlockBadge}}" class="unlock-icon" src="{{assets.unlockBadge}}"></cover-image>
        <cover-view class="unlock-copy">
          <cover-view class="unlock-name">{{rewardModal.ecosystemUnlockName || rewardModal.sceneName}}</cover-view>
          <cover-view class="unlock-desc">{{rewardModal.ecosystemUnlockDesc}}</cover-view>
        </cover-view>
      </cover-view>

      <cover-view wx:if="{{rewardModal.achievementName}}" class="achievement-line">新成就：{{rewardModal.achievementName}}</cover-view>
      <cover-view wx:if="{{rewardModal.isPerfect}}" class="perfect-line">六个生态区全部点亮，今日宝箱已开启</cover-view>

      <cover-view class="reward-actions">
        <cover-view class="ghost-button" bindtap="continueNext">继续下一个</cover-view>
        <cover-view class="solid-button" bindtap="goRewardEcology">查看生态变化</cover-view>
      </cover-view>
    </cover-view>
  </cover-view>

  <view class="checkin-head">
    <view>
      <view class="scan-label">行动中心</view>
      <view class="section-title">今日打卡</view>
      <view class="muted head-subtitle">{{dateDisplay.fullText}} · 先选一个真实要完成的行动</view>
    </view>
    <view class="today-box">
      <view class="today-count">{{stats.today.completedCount}}/6</view>
      <view class="today-label">今日点亮</view>
    </view>
  </view>

  <view class="daily-strip cabin-panel">
    <view class="daily-copy">
      <view class="scan-label">今日宝箱</view>
      <view class="daily-title">{{dailyChest.ready ? '宝箱已开启' : '点亮六类可开启宝箱'}}</view>
      <view class="muted">{{dailyChest.label}} · 完成越均衡，星球生态越完整</view>
    </view>
    <view class="daily-ring">
      <view>{{dailyChest.progress}}%</view>
      <text>进度</text>
    </view>
    <view class="daily-track">
      <view class="daily-fill" style="width: {{dailyChest.progress}}%;"></view>
    </view>
  </view>

  <view class="dimension-board cabin-panel">
    <view class="board-head">
      <view>
        <view class="scan-label">选择生态区</view>
        <view class="board-title">今天先点亮哪一块？</view>
      </view>
      <view class="scene-pill" style="color: {{active.color}};">{{active.sceneName}}</view>
    </view>
    <scroll-view scroll-x class="dimension-scroll">
      <view class="dimension-row">
        <view
          wx:for="{{dimensions}}"
          wx:key="id"
          class="dimension-chip {{activeId === item.id ? 'active' : ''}} {{item.completed ? 'done' : ''}}"
          style="border-color: {{activeId === item.id ? item.color : 'rgba(23,32,51,0.06)'}};"
          data-id="{{item.id}}"
          bindtap="selectDimension"
        >
          <view class="dimension-icon" style="background: {{item.color}};">
            <image src="{{item.icon}}" mode="aspectFit"></image>
          </view>
          <view>
            <view class="dimension-name">{{item.name}}</view>
            <view class="dimension-state">{{item.completed ? '已点亮' : '待行动'}}</view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="action-panel cabin-panel">
    <view class="panel-top">
      <view>
        <view class="scan-label">{{active.name}}行动</view>
        <view class="panel-title">写下这次要完成什么</view>
      </view>
      <view class="compact-state">{{activePlans.length}} 个常用计划</view>
    </view>

    <view wx:if="{{activePlans.length}}" class="saved-plan-strip">
      <scroll-view scroll-x class="plan-scroll compact">
        <view class="plan-row">
          <view wx:for="{{activePlans}}" wx:key="id" class="plan-card compact" data-id="{{item.id}}" bindtap="usePlan" bindlongpress="deletePlan">
            <view class="plan-dot" style="background: {{item.color}};"></view>
            <view class="plan-title">{{item.title}}</view>
            <view class="muted plan-summary">{{item.summary}}</view>
          </view>
        </view>
      </scroll-view>
    </view>

    <input
      class="action-input"
      value="{{form.customAction}}"
      placeholder="{{active.preset.placeholder}}"
      bindinput="inputCustomAction"
    />

    <view class="quick-row">
      <view
        wx:for="{{quickActions}}"
        wx:key="id"
        class="quick-action"
        data-id="{{item.id}}"
        bindtap="useQuickAction"
      >
        <view class="quick-title">{{item.title}}</view>
        <view class="muted quick-desc">{{item.desc}}</view>
      </view>
    </view>

    <view class="lite-fields">
      <view>
        <view class="field-label">{{active.preset.metricLabel}}</view>
        <scroll-view scroll-x class="chip-scroll">
          <view class="chip-row">
            <view wx:for="{{active.preset.metricOptions}}" wx:key="*this" class="choice-chip {{form.metric === item ? 'active' : ''}}" data-value="{{item}}" bindtap="chooseMetric">{{item}}</view>
          </view>
        </scroll-view>
      </view>
      <view>
        <view class="field-label">{{active.preset.moodLabel}}</view>
        <scroll-view scroll-x class="chip-scroll">
          <view class="chip-row">
            <view wx:for="{{active.preset.moodOptions}}" wx:key="*this" class="choice-chip {{form.mood === item ? 'active' : ''}}" data-value="{{item}}" bindtap="chooseMood">{{item}}</view>
          </view>
        </scroll-view>
      </view>
    </view>

    <textarea class="note-input" value="{{form.note}}" placeholder="可选：完成后想记录的结果或感受" bindinput="inputNote"></textarea>

    <view class="action-buttons">
      <view class="save-button" bindtap="saveCurrentPlan">保存计划</view>
      <view class="room-button" bindtap="enterActionRoom">进入行动舱</view>
      <view class="primary-button submit-button" bindtap="submitActive">立即完成</view>
    </view>
  </view>

  <view class="plan-panel cabin-panel">
    <view class="board-head">
      <view>
        <view class="scan-label">我的计划库</view>
        <view class="board-title">下次直接复用</view>
      </view>
      <view class="muted">长按删除</view>
    </view>
    <scroll-view wx:if="{{customPlans.length}}" scroll-x class="plan-scroll">
      <view class="plan-row">
        <view wx:for="{{customPlans}}" wx:key="id" class="plan-card" data-id="{{item.id}}" bindtap="usePlan" bindlongpress="deletePlan">
          <view class="plan-meta">
            <view class="plan-dot" style="background: {{item.color}};"></view>
            <view class="plan-dimension">{{item.dimensionName}}</view>
          </view>
          <view class="plan-title">{{item.title}}</view>
          <view class="muted plan-summary">{{item.summary}}</view>
        </view>
      </view>
    </scroll-view>
    <view wx:else class="empty-plan">把常做的学习、工作、运动计划保存下来，下次打卡时点一下就能进入行动舱。</view>
  </view>
</view>
