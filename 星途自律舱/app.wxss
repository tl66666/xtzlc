page {
  min-height: 100vh;
  color: #172033;
  background: #f4f0e7;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 30rpx 30rpx 48rpx;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.2), rgba(244,240,231,0.88)),
    radial-gradient(circle at 18% 6%, rgba(255, 218, 145, 0.24), transparent 28%),
    radial-gradient(circle at 86% 18%, rgba(136, 189, 214, 0.18), transparent 30%),
    linear-gradient(180deg, #eaf5fb 0%, #f5efe2 58%, #efe6d5 100%);
  background-size: cover;
  background-position: center top;
}

.page-bg {
  position: fixed;
  z-index: 0;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  opacity: 0.96;
  pointer-events: none;
}

.page > view:not(.page-bg),
.page > scroll-view,
.page > image:not(.page-bg),
.page > canvas {
  position: relative;
  z-index: 1;
}

.page::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 360rpx;
  pointer-events: none;
  background:
    radial-gradient(circle at 12% 24%, rgba(255,255,255,0.66) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 76% 30%, rgba(245,200,66,0.28) 0 2rpx, transparent 3rpx),
    linear-gradient(180deg, rgba(255,255,255,0.22), transparent);
  opacity: 0.5;
}

.section-title {
  font-size: 42rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.muted {
  color: rgba(23, 32, 51, 0.58);
}

.glass-card {
  position: relative;
  border: 1rpx solid rgba(255, 255, 255, 0.09);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.68);
}

.cabin-panel {
  position: relative;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 26rpx;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.82), rgba(255,255,255,0.62));
  box-shadow: 0 22rpx 52rpx rgba(91, 75, 45, 0.12);
}

.cabin-panel::before {
  content: "";
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  top: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(212,151,48,0.42), transparent);
}

.gold {
  color: #f5c842;
}

.primary-button {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  color: #120f05;
  font-weight: 700;
  background: linear-gradient(135deg, #ffe89a, #f5c842 58%, #b98f24);
}

.line-icon {
  position: relative;
  width: 42rpx;
  height: 42rpx;
}

.line-icon::before,
.line-icon::after,
.line-icon .stroke {
  content: "";
  position: absolute;
  box-sizing: border-box;
  border-color: currentColor;
}

.icon-sport::before {
  left: 8rpx;
  top: 8rpx;
  width: 25rpx;
  height: 25rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: rotate(-24deg);
}

.icon-sport::after {
  right: 3rpx;
  bottom: 8rpx;
  width: 26rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: currentColor;
  transform: rotate(-18deg);
}

.icon-diet::before {
  left: 7rpx;
  top: 6rpx;
  width: 28rpx;
  height: 30rpx;
  border: 4rpx solid currentColor;
  border-radius: 28rpx 4rpx 28rpx 4rpx;
  transform: rotate(-26deg);
}

.icon-diet::after {
  left: 20rpx;
  top: 14rpx;
  width: 4rpx;
  height: 24rpx;
  border-radius: 999rpx;
  background: currentColor;
  transform: rotate(36deg);
}

.icon-study::before {
  left: 5rpx;
  top: 9rpx;
  width: 32rpx;
  height: 25rpx;
  border: 4rpx solid currentColor;
  border-radius: 5rpx;
}

.icon-study::after {
  left: 20rpx;
  top: 9rpx;
  width: 3rpx;
  height: 27rpx;
  background: currentColor;
}

.icon-work::before {
  left: 13rpx;
  top: 4rpx;
  width: 16rpx;
  height: 22rpx;
  background: currentColor;
  transform: skewX(-18deg);
}

.icon-work::after {
  left: 17rpx;
  top: 20rpx;
  width: 12rpx;
  height: 20rpx;
  background: currentColor;
  transform: skewX(-18deg) rotate(28deg);
}

.icon-plan::before {
  left: 5rpx;
  top: 5rpx;
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.icon-plan::after {
  left: 17rpx;
  top: 17rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: currentColor;
}

.icon-sleep::before {
  left: 9rpx;
  top: 4rpx;
  width: 26rpx;
  height: 34rpx;
  border-radius: 50%;
  box-shadow: -9rpx 4rpx 0 0 currentColor;
  transform: rotate(18deg);
}

.scan-label {
  color: rgba(181, 118, 34, 0.9);
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}
